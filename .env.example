# EchoPath AI Environment Configuration
# Copy this file to .env and update the values below

# OpenAI API Configuration (Optional - for advanced AI features)
OPENAI_API_KEY=sk-your_actual_openai_api_key_here

# Environment Configuration
ENVIRONMENT=development
DEBUG=true

# Backend Server Configuration
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Database Configuration (for future use)
DATABASE_URL=postgresql://user:password@localhost/echopath_db

# Security Configuration
SECRET_KEY=your_secure_random_secret_key_here_minimum_32_characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Audio Processing Configuration
MAX_AUDIO_FILE_SIZE_MB=10
SUPPORTED_AUDIO_FORMATS=wav,mp3,m4a,ogg

# Session Configuration
SESSION_TIMEOUT_MINUTES=30
MAX_DAILY_SESSIONS=10

# Compliance Configuration (HIPAA/COPPA for healthcare)
DATA_RETENTION_DAYS=2555
AUDIT_LOG_RETENTION_DAYS=2555
HIPAA_COMPLIANCE_MODE=true

# Speech Recognition Configuration
SPEECH_RECOGNITION_TIMEOUT=10
SPEECH_CONFIDENCE_THRESHOLD=0.5

# Therapy Configuration
DEFAULT_SESSION_LENGTH=15
MAX_EXERCISES_PER_SESSION=10
DIFFICULTY_ADJUSTMENT_THRESHOLD=0.8